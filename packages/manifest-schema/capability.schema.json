{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pangaea Capability Manifest v0.1",
  "type": "object",
  "required": ["manifest", "capability", "runtime", "auth", "entities", "intents", "actions"],
  "additionalProperties": true,
  "properties": {
    "manifest": {
      "type": "string",
      "description": "Manifest spec version"
    },
    "capability": {
      "type": "object",
      "required": ["id", "name", "description", "owner", "lifecycle", "version"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9]*)+$",
          "description": "Reverse-DNS capability identifier"
        },
        "name": {"type": "string"},
        "description": {"type": "string"},
        "owner": {"type": "string"},
        "lifecycle": {
          "type": "string",
          "enum": ["draft", "beta", "ga", "deprecated"]
        },
        "version": {"type": "string"}
      }
    },
    "runtime": {
      "type": "object",
      "required": ["base_url", "health_url", "fulfillment_modes"],
      "additionalProperties": true,
      "properties": {
        "base_url": {"type": "string"},
        "health_url": {"type": "string"},
        "fulfillment_modes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["idp", "audience", "scopes"],
      "additionalProperties": true,
      "properties": {
        "idp": {"type": "string"},
        "audience": {"type": "string"},
        "scopes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": true,
        "properties": {
          "type": {"type": "string"},
          "owns": {"type": "boolean"},
          "ref": {"type": "string"}
        }
      }
    },
    "intents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "utterances"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "utterances": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "risk"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string"},
          "risk": {
            "type": "string",
            "enum": ["read", "reversible", "consequential"]
          },
          "confirmation": {
            "type": "object",
            "required": ["template", "show_fields", "requires"],
            "additionalProperties": true,
            "properties": {
              "template": {"type": "string"},
              "show_fields": {
                "type": "array",
                "items": {"type": "string"}
              },
              "requires": {
                "type": "array",
                "items": {"type": "string"}
              },
              "voice_blocked": {"type": "boolean"}
            }
          }
        },
        "if": {
          "properties": {
            "risk": {"const": "consequential"}
          },
          "required": ["risk"]
        },
        "then": {
          "required": ["confirmation"]
        }
      }
    }
  }
}
