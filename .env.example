# ── Pangaea environment variables ─────────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env.

# Service ports
TIMESHEET_STUB_PORT=8101
PEOPLE_DATA_STUB_PORT=8102
PERMISSIONS_STUB_PORT=8103
GATEWAY_PORT=8200
REGISTRY_PORT=8201
BROKER_PORT=8202
ROUTER_PORT=8203

# Service URLs (used by services to call each other)
TIMESHEET_URL=http://localhost:8101
PEOPLE_DATA_URL=http://localhost:8102
PERMISSIONS_URL=http://localhost:8103
GATEWAY_URL=http://localhost:8200
REGISTRY_URL=http://localhost:8201
BROKER_URL=http://localhost:8202
ROUTER_URL=http://localhost:8203

# Keycloak (dev IdP)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=pangaea
KEYCLOAK_CLIENT_ID=pangaea-platform
KEYCLOAK_CLIENT_SECRET=dev-secret-change-in-prod

# Broker JWT secret (HS256, dev only — rotate in prod)
JWT_SECRET=pangaea-dev-secret-change-in-prod

# Postgres (Phase 1+)
DATABASE_URL=postgresql://pangaea:pangaea@localhost:5432/pangaea

# Redis (Phase 1+)
REDIS_URL=redis://localhost:6379/0

# NATS (Phase 1+)
NATS_URL=nats://localhost:4222
